# ── Stellar DeFi Platform — Environment Variables ──
# Copy this file to .env and fill in the values.
# Run `npm run setup` from the project root to auto-generate real values.

VITE_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_NETWORK=TESTNET

# STLR Token Issuer (generated by setup script)
VITE_STLR_ISSUER=G...YOUR_ISSUER_PUBLIC_KEY
VITE_STLR_ISSUER_SECRET=S...YOUR_ISSUER_SECRET_KEY

# Staking Escrow Account (generated by setup script)
VITE_STAKING_ACCOUNT=G...YOUR_STAKING_PUBLIC_KEY
VITE_STAKING_SECRET=S...YOUR_STAKING_SECRET_KEY

# Sentry error tracking (optional)
# VITE_SENTRY_DSN=https://...@sentry.io/...
